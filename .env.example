# AI Investment Advisor — Environment Variables
# Copy this to .env and fill in your real values
# NEVER commit the .env file to git!

# Anthropic API Key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gmail credentials — use an App Password, not your regular password
# Create one at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here

# Where to send the monthly report.
# Single recipient: RECIPIENT_EMAIL=you@example.com
# Multiple subscribers (BCC'd, addresses hidden from each other):
#   RECIPIENT_EMAIL=alice@example.com,bob@example.com,carol@example.com
RECIPIENT_EMAIL=your.email@gmail.com
